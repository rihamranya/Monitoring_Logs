# Environment
.env
.env.local

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Prometheus
PROMETHEUS_URL=http://localhost:9090

# Loki
LOKI_URL=http://localhost:3100

# Jaeger
JAEGER_URL=http://localhost:16686

# Ollama (LLM Local Gratuit) 🆓
# Modèles recommandés: qwen2.5:0.5b, llama3.2:1b, gemma3:270m
# Installer: ollama pull qwen2.5:0.5b (ou autre modèle)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# SMTP
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=4670fd4942cfbd
SMTP_PASSWORD=37b1dd040ba667
SMTP_FROM=rca@monitoring.local
NOTIFICATION_EMAIL=oncall@monitoring.local
SMTP_USE_TLS=true
SMTP_REQUIRE_AUTH=true

# Alert processing
ALERT_PROCESSING_TIMEOUT=300
SOURCE_TIMEOUT_SECONDS=8
CONTEXT_LOOKBACK_MINUTES=15
DB_PATH=rca_history.db

# Logging
LOG_LEVEL=INFO
DEBUG=false
